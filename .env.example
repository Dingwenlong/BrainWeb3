APP_ENV=local
APP_STAGE=local
APP_PORT=8080
AUTH_JWT_SECRET=brainweb3-demo-jwt-secret-2026-04-21-neural-trust-console
AUTH_TOKEN_TTL_HOURS=12
AUTH_REFRESH_TOKEN_TTL_DAYS=14
AUTH_PASSWORD_RESET_TTL_MINUTES=30
AUTH_DEMO_PASSWORD=brainweb3-demo
AUTH_ALLOW_DEMO_BOOTSTRAP=true
AUTH_ALLOW_DEMO_PASSWORD_LOGIN=true
IDENTITY_ISSUER_DID=did:brainweb3:issuer:platform
IDENTITY_CREDENTIAL_TTL_DAYS=365
IDENTITY_CREDENTIAL_SECRET=brainweb3-demo-identity-secret-2026-04-21
IDENTITY_REVOKED_ACTORS=
IDENTITY_REVOKED_ORGANIZATIONS=

MYSQL_DATABASE=brainweb3
MYSQL_USERNAME=brainweb3
MYSQL_PASSWORD=brainweb3
MYSQL_PORT=3306

REDIS_PORT=6379

IPFS_API_PORT=5001
IPFS_GATEWAY_PORT=8088
IPFS_SWARM_PORT=4001

EEG_SERVICE_PORT=8101
FEDERATED_SERVICE_PORT=8102
FRONTEND_PORT=5173
BRAINWEB3_SAMPLE_ROOT=./.brainweb3-samples

CHAIN_PROVIDER=fisco-bcos-3
CHAIN_ENABLED=false
CHAIN_GROUP=group0
CHAIN_CONTRACT_NAME=DataNotary
CHAIN_CONTRACT_ADDRESS=
CHAIN_AUTO_DEPLOY=true
CHAIN_BUSINESS_CONTRACT_NAME=BusinessEventAnchor
CHAIN_BUSINESS_CONTRACT_ADDRESS=
CHAIN_BUSINESS_CONTRACT_AUTO_DEPLOY=false
CHAIN_BUSINESS_CONTRACT_ABI_PATH=classpath:fisco/contracts/DataNotary.abi
CHAIN_BUSINESS_CONTRACT_BIN_PATH=classpath:fisco/contracts/DataNotary.bin
CHAIN_REQUIRED_EVENT_TYPES=ACCESS_APPROVED,ACCESS_REVOKED,TRAINING_COMPLETED,TRAINING_FAILED,DESTRUCTION_COMPLETED
CHAIN_OPTIONAL_EVENT_TYPES=DESTRUCTION_STORAGE_PURGED,MODEL_REGISTERED,MODEL_GOVERNED
CHAIN_DISABLED_EVENT_TYPES=
CHAIN_CONFIG_PATH=classpath:fisco/config-example.toml

STORAGE_PROVIDER=local
STORAGE_LOCAL_ROOT=./.brainweb3-storage
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=brainweb3
MINIO_SECRET_KEY=brainweb3secret
MINIO_BUCKET=brainweb3-datasets
MINIO_REGION=
MINIO_AUTO_CREATE_BUCKET=true
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
EEG_SERVICE_BASE_URL=http://localhost:8101
