# BrainWeb3 production/staging environment example
# Copy to .env.production or your deployment secret manager and replace placeholders.

APP_ENV=production
APP_STAGE=production
APP_PORT=8080

SPRING_DATASOURCE_URL=jdbc:mysql://mysql.internal:3306/brainweb3?createDatabaseIfNotExist=true&useSSL=true&allowPublicKeyRetrieval=false&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=brainweb3_app
SPRING_DATASOURCE_PASSWORD=replace-with-strong-db-password

AUTH_JWT_SECRET=replace-with-32-byte-or-longer-jwt-secret
AUTH_TOKEN_TTL_HOURS=12
AUTH_REFRESH_TOKEN_TTL_DAYS=14
AUTH_PASSWORD_RESET_TTL_MINUTES=30
AUTH_DEMO_PASSWORD=disable-demo-password-before-prod
AUTH_ALLOW_DEMO_BOOTSTRAP=false
AUTH_ALLOW_DEMO_PASSWORD_LOGIN=false

IDENTITY_ISSUER_DID=did:brainweb3:issuer:prod
IDENTITY_CREDENTIAL_TTL_DAYS=365
IDENTITY_CREDENTIAL_SECRET=replace-with-prod-credential-secret
IDENTITY_REVOKED_ACTORS=
IDENTITY_REVOKED_ORGANIZATIONS=

EEG_SERVICE_BASE_URL=http://eeg-service.internal:8101

CHAIN_PROVIDER=fisco-bcos-3
CHAIN_ENABLED=true
CHAIN_GROUP=group0
CHAIN_CONTRACT_NAME=DataNotary
CHAIN_CONTRACT_ADDRESS=replace-with-deployed-data-contract
CHAIN_AUTO_DEPLOY=false
CHAIN_BUSINESS_CONTRACT_NAME=BusinessEventAnchor
CHAIN_BUSINESS_CONTRACT_ADDRESS=replace-with-deployed-business-contract
CHAIN_BUSINESS_CONTRACT_AUTO_DEPLOY=false
CHAIN_BUSINESS_CONTRACT_ABI_PATH=classpath:fisco/contracts/DataNotary.abi
CHAIN_BUSINESS_CONTRACT_BIN_PATH=classpath:fisco/contracts/DataNotary.bin
CHAIN_REQUIRED_EVENT_TYPES=ACCESS_APPROVED,ACCESS_REVOKED,TRAINING_COMPLETED,TRAINING_FAILED,DESTRUCTION_COMPLETED
CHAIN_OPTIONAL_EVENT_TYPES=DESTRUCTION_STORAGE_PURGED,MODEL_REGISTERED,MODEL_GOVERNED
CHAIN_DISABLED_EVENT_TYPES=
CHAIN_CONFIG_PATH=/opt/brainweb3/fisco/config.toml

STORAGE_PROVIDER=minio
STORAGE_LOCAL_ROOT=/opt/brainweb3/storage
MINIO_ENDPOINT=https://minio.internal:9000
MINIO_ACCESS_KEY=replace-with-minio-access-key
MINIO_SECRET_KEY=replace-with-minio-secret
MINIO_BUCKET=brainweb3-datasets
MINIO_REGION=cn-south-1
MINIO_AUTO_CREATE_BUCKET=false

BRAINWEB3_SAMPLE_ROOT=/opt/brainweb3/samples
